#include <iostream>
#include <string>
using namespace std;

int opcion1(int byte1);
double opcion2(double terabyte1);
double opcion3(double gigabyte1);

int main()
{
    int operacion = 0;
    cout << "Este programa convierte memorias de almacenamiento" << endl << endl;
    cout << "Ingrese la opcion que requiera:" << endl;
    cout << "1. Bytes a Kilobytes" << endl;
    cout << "2. Terabytes a Megabytes" << endl;
    cout << "3. Gigabytes a Petabytes" << endl;
    cout << "Ingrese su respuesta: ";
    cin >> operacion;
    switch(operacion)
    {
        case 1:
        {
            cout << endl;
            int byte = 0;
            int kilobyte = 0;
            cout << "Ingrese los bytes: ";
            cin >> byte;
            kilobyte = opcion1(byte);
            cout << endl << "El resultado es de: " << kilobyte << " kilobytes";
        }
        break;
            
        case 2:
        {
            cout << endl;
            double terabyte = 0;
            double megabyte = 0;
            cout << "Ingrese los terabytes: ";
            cin >> terabyte;
            megabyte = opcion2(terabyte);
            cout <<  endl << "El resultado es de: " << megabyte << " megabytes";
        }
        break;
        
        case 3:
        {
            cout << endl;
            double gigabyte = 0;
            double petabyte = 0;
            cout << "Ingrese los gigabytes: ";
            cin >> gigabyte;
            petabyte = opcion3(gigabyte);
            cout <<  endl << "El resultado es de: " << petabyte << " petabytes";
        }
        break;
        
        default:
        cout << "Porfavor ingrese una de las opciones disponibles, se volvera a iniciar..." << endl << endl;
        return main();
    }
}

int opcion1(int byte1)
{
    int kilobyte1 = byte1 / 1000;
    return kilobyte1;
}

double opcion2(double terabyte1)
{
    int megabyte1 = terabyte1 * 1000000;
    return megabyte1;
}

double opcion3(double gigabyte1)
{
    double petabyte1 = gigabyte1 / 1000000;
    return petabyte1;
}
